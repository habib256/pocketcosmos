  "narratives": {
    "Soleil": { "title": "Le Coeur du Système", "text": "Le Soleil, phare de notre système, dont la gravité dirige la danse des planètes." },
    "Mercure": { "text": "Petite et rapide, battue par les vents solaires, Mercure est un monde de roche et d'extrêmes." },
    "Vénus": { "text": "Voilée de nuages acides, Vénus brûle d'une chaleur écrasante sous une atmosphère épaisse." },
    "Terre": { "text": "Berceau de l'humanité, la Terre abrite océans, continents et notre point de départ." },
    "Lune": { "text": "Gardienne nocturne, la Lune a guidé nos premiers pas au-delà de la Terre." },
    "Mars": { "text": "Planète rouge de poussière et de promesses, but des rêves d'exploration." },
    "Phobos": { "text": "Étrange rocher en orbite basse, Phobos file vite au-dessus de Mars." },
    "Deimos": { "text": "Lointain et timide, Deimos survole Mars sur une orbite silencieuse." },
    "Cérès": { "text": "Première des planètes naines, Cérès repose dans la ceinture d'astéroïdes." },
    "Jupiter": { "text": "Géante gazeuse striée de tempêtes, Jupiter règne avec ses lunes innombrables." },
    "Io": { "text": "Mondes de feu et de soufre, Io est bousculée par la gravité de Jupiter." },
    "Europe": { "text": "Sous sa glace, Europe pourrait cacher un océan et des secrets de vie." },
    "Ganymède": { "text": "Plus grande lune du système solaire, Ganymède est un monde à part entière." },
    "Callisto": { "text": "Ancienne et criblée de cratères, Callisto témoigne d'un passé violent." },
    "Saturne": { "text": "Avec ses anneaux majestueux, Saturne fascine depuis toujours les observateurs." },
    "Titan": { "text": "Brume orange, lacs d'hydrocarbures — Titan ressemble à une Terre primitive." },
    "Encelade": { "text": "Geysers glacés et océan interne, Encelade défie nos certitudes." },
    "Uranus": { "text": "Penchée sur le côté, Uranus tourne comme une bille turquoise au ralenti." },
    "Neptune": { "text": "Bleue et lointaine, Neptune abrite des vents supersoniques." },
    "Pluton": { "text": "Aux confins, Pluton et ses glaces racontent la naissance du système." }
  },
